# OpenAI API key (required — get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI model to use for content moderation
AI_MODEL=gpt-4o-mini

# Request timeout in seconds
AI_GRADER_TIMEOUT=60

# OpenEnv server URL (for inference.py)
OPENENV_URL=http://127.0.0.1:7860

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Optional: channel ID where escalated messages are posted
DISCORD_MOD_LOG_CHANNEL_ID=

# Discord classifier: auto | moderator | rl
# auto: local HF (USE_LOCAL_LLM) uses inference RL path; else OpenAI moderator
DISCORD_CLASSIFIER=auto
